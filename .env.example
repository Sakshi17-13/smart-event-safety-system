MONGODB_URI=mongodb://127.0.0.1:27017/tourist-safety-system

# Render sets PORT automatically. Local default is 5000.
PORT=5000

# Comma-separated list of frontend origins (production). Matches Express + Socket.IO CORS.
# Example: ALLOWED_ORIGINS=https://your-frontend.onrender.com
ALLOWED_ORIGINS=http://localhost:5173

# Optional alternate to ALLOWED_ORIGINS if you only need a single URL.
# FRONTEND_URL=https://your-frontend.onrender.com
